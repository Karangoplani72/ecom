rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // 1. CORE AUTHENTICATION FUNCTIONS
    // ========================================================================
    function isLoggedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isLoggedIn() && role in getUserData().roles;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superAdmin');
    }

    function isNonEmptyString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    // ========================================================================
    // 2. USERS
    // Covers: AuthRepositoryImpl, AddressRepositoryImpl, CartRepositoryImpl,
    //         WishlistRepositoryImpl, CommunicationRepositoryImpl (tokens),
    //         OrderRepositoryImpl (notifications subcollection),
    //         AdminUserRepositoryImpl
    // ========================================================================
    match /users/{userId} {
      // Own profile read; admins can list/read all (AdminUserRepositoryImpl.watchUsers)
      allow get:  if isOwner(userId) || hasRole('admin') || hasRole('superAdmin');
      allow list: if hasRole('admin') || hasRole('superAdmin');

      // Own profile create (signup)
      allow create: if isLoggedIn() && isOwner(userId);

      // Own profile update — blocked fields enforced here.
      // Admin can update roles/isActive (AdminUserRepositoryImpl.updateRoles/updateStatus).
      allow update: if (
                      isOwner(userId)
                      && !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny(['roles', 'isActive', 'walletBalance', 'sellerApproved'])
                      && (
                           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sellerApplicationStatus'])
                           || request.resource.data.sellerApplicationStatus == 'pending'
                         )
                    )
                    || hasRole('admin')
                    || hasRole('superAdmin');

      allow delete: if hasRole('superAdmin');

      // --- Push notification tokens (CommunicationRepositoryImpl) ---
      match /tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }

      // --- Addresses (AddressRepositoryImpl) ---
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      // --- Cart (CartRepositoryImpl) ---
      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }

      // --- Wishlist (WishlistRepositoryImpl) ---
      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId);
      }

      // --- In-app notifications (OrderRepositoryImpl._addNotification) ---
      // Written inside transactions on behalf of both buyer and seller storeId.
      // The storeId equals the seller's userId in this app, so allow any
      // logged-in user to create notifications for any userId (backend-style
      // write via client transaction).
      match /notifications/{notifId} {
        allow read:   if isOwner(userId);
        allow create: if false; // Cloud Functions/Admin SDK only
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasOnly(['isRead']);
        allow delete: if isOwner(userId);
      }
    }

    // ========================================================================
    // 3. STORES
    // Covers: SellerStoreRepositoryImpl, AdminRepositoryImpl (approve/reject)
    // ========================================================================
    match /stores/{storeId} {
      // Verified stores are public; unverified stores visible to owner & admin
      allow get: if resource.data.status == 'verified'
                 || (isLoggedIn() && resource.data.sellerId == request.auth.uid)
                 || hasRole('admin')
                 || hasRole('superAdmin');

      // Admins list all stores; SellerStoreRepositoryImpl.getStoresByStatus lists by status
      allow list: if hasRole('admin') || hasRole('superAdmin');

      // Seller updates own store; admin updates any (approval flow)
      allow update: if (isLoggedIn() && resource.data.sellerId == request.auth.uid)
                    || hasRole('admin')
                    || hasRole('superAdmin');

      // Store docs created by admin during seller approval transaction
      allow create: if hasRole('admin') || hasRole('superAdmin');
      allow delete: if hasRole('superAdmin');

      // --- Store products subcollection (SellerProductRepositoryImpl) ---
      match /products/{productId} {
        // Owner or admin can get a single product
        allow get: if (isLoggedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.sellerId == request.auth.uid)
                   || hasRole('admin');

        // Owner lists their own inventory (watchProducts, getProductsByCategory, searchProducts)
        allow list: if isLoggedIn()
                    && get(/databases/$(database)/documents/stores/$(storeId)).data.sellerId == request.auth.uid;

        // Owner manages their inventory (create/update/delete/updateStock/updateStatus)
        allow write: if isLoggedIn()
                     && get(/databases/$(database)/documents/stores/$(storeId)).data.sellerId == request.auth.uid;
      }
    }

    // ========================================================================
    // 4. CATALOG
    // Covers: MarketplaceRepositoryImpl, SellerProductRepositoryImpl (dual-write),
    //         WishlistRepositoryImpl (catalog.doc read), OrderRepositoryImpl
    //         (catalog.doc read+update in checkout transaction)
    // ========================================================================
    match /catalog/{productId} {
      // Single-doc get: product must be active and store verified
      // (WishlistRepositoryImpl fetches individual catalog docs)
      allow get: if resource.data.status == 'active'
                 && exists(/databases/$(database)/documents/stores/$(resource.data.storeId))
                 && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.status == 'verified';

      // resource.data assertions enforce that queries MUST include these filters unless bypassed by role.
      allow list: if (resource.data.status == 'active') || hasRole('admin') || hasRole('superAdmin') || (isLoggedIn() && resource.data.storeId == request.auth.uid);

      // Seller creates catalog entry (dual-write batch in createProduct)
      allow create: if isLoggedIn()
                    && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.sellerId == request.auth.uid;

      // Seller can update their own catalog entry freely.
      // Stock deduction (checkout) now runs via the verifyAndFinalizePayment Cloud Function
      // using the Admin SDK, which bypasses these rules entirely — so client-side
      // catalog updates are now locked down to sellers only.
      allow update: if isLoggedIn() && (
        get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.sellerId == request.auth.uid
        || hasRole('admin') || hasRole('superAdmin')
      );

      // Only owner can delete (deleteProduct dual-write batch)
      allow delete: if isLoggedIn()
                    && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.sellerId == request.auth.uid;
    }

    // ========================================================================
    // 5. ORDERS
    // Covers: OrderRepositoryImpl (checkout, watchBuyerOrders, watchSellerOrders,
    //         updateOrderStatus, getOrderById, cancelOrder),
    //         SellerDashboardRepositoryImpl, SellerAnalyticsRepositoryImpl
    // ========================================================================
    match /orders/{orderId} {
      // Single-doc get by buyer, seller, or admin
      allow get: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.storeId == request.auth.uid ||
        hasRole('admin') || hasRole('superAdmin')
      );

      // List queries: watchBuyerOrders (buyerId==uid), watchSellerOrders (storeId==uid),
      // analytics queries (storeId==sellerId). Require equality filter matching caller's uid.
      allow list: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.storeId == request.auth.uid ||
        hasRole('admin') || hasRole('superAdmin')
      );

      // Buyer creates orders at checkout
      allow create: if isLoggedIn() && request.resource.data.buyerId == request.auth.uid;

      // Seller updates status; admin updates anything
      allow update: if isLoggedIn() && (
        (resource.data.storeId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
        || hasRole('admin') || hasRole('superAdmin')
      );

      allow delete: if hasRole('superAdmin');
    }

    // ========================================================================
    // 6. SELLER APPLICATIONS
    // Covers: SellerApplicationRepositoryImpl, AdminRepositoryImpl
    // ========================================================================
    match /sellerApplications/{applicationId} {
      // User reads own application; admin reads all (fetchPendingSellerApplications)
      allow get:  if isLoggedIn() && (applicationId == request.auth.uid || hasRole('admin') || hasRole('superAdmin'));
      allow list: if hasRole('admin') || hasRole('superAdmin');

      // User submits own application (applicationId == userId enforced)
      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid
                    && applicationId == request.auth.uid;

      // User re-submits edits to own application (no status/review fields);
      // Admin approves/rejects (approveSellerApplication, rejectSellerApplication,
      // requestChangesOnSellerApplication)
      allow update: if isLoggedIn() && (
        (applicationId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['status', 'reviewedAt', 'reviewedBy', 'rejectionReason']))
        || hasRole('admin') || hasRole('superAdmin')
      );

      allow delete: if hasRole('superAdmin');
    }

    // ========================================================================
    // 7. FINANCIAL — PAYMENT INTENTS & TRANSACTIONS
    // Covers: PaymentRepositoryImpl, SellerFinanceRepositoryImpl
    // ========================================================================
    match /payment_intents/{intentId} {
      allow create: if isLoggedIn();
      allow read:   if isLoggedIn() && resource.data.buyerId == request.auth.uid;
      allow update, delete: if false; // Cloud Functions only
    }

    match /payment_failures/{failureId} {
      allow create: if isLoggedIn()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.razorpayOrderId is string
                    && request.resource.data.errorCode is int
                    && request.resource.data.errorMessage is string;
      allow read: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        hasRole('admin') || hasRole('superAdmin')
      );
      allow update, delete: if false;
    }

    match /transactions/{transactionId} {
      // Buyer sees receipts; seller sees payouts (storeId == activeStoreId)
      // Also covers SellerFinanceRepositoryImpl.getTransactions (storeId filter)
      allow get: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.storeId == request.auth.uid
      );
      allow list: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.storeId == request.auth.uid ||
        hasRole('admin') || hasRole('superAdmin')
      );
      allow write: if false; // Cloud Functions only
    }

    // ========================================================================
    // 8. SELLER WALLETS
    // Covers: SellerFinanceRepositoryImpl.getMerchantWallet
    // ========================================================================
    match /wallets/{sellerId} {
      allow read: if isLoggedIn() && request.auth.uid == sellerId;
      allow write: if false; // Cloud Functions only
    }

    // ========================================================================
    // 9. PAYOUTS
    // Covers: SellerFinanceRepositoryImpl.requestPayout, getPayoutStatus
    // ========================================================================
    match /payouts/{payoutId} {
      allow read:   if isLoggedIn() && resource.data.storeId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.storeId == request.auth.uid;
      allow update, delete: if false; // Cloud Functions only
    }

    // ========================================================================
    // 10. BANK ACCOUNTS
    // Covers: SellerFinanceRepositoryImpl.updateBankAccount
    // ========================================================================
    match /bankAccounts/{accountId} {
      allow read:   if isLoggedIn() && resource.data.storeId == request.auth.uid;
      allow create, update:  if isLoggedIn()
                    && request.resource.data.storeId == request.auth.uid
                    && request.resource.data.accountNumber is string
                    && request.resource.data.ifscCode is string
                    && request.resource.data.accountHolderName is string
                    && request.resource.data.bankName is string
                    && request.resource.data.isVerified == false;
      allow delete: if false;
    }

    // ========================================================================
    // 11. CHATS & MESSAGES
    // Covers: CommunicationRepositoryImpl
    // ========================================================================
    match /chats/{roomId} {
      allow read, update: if isLoggedIn() && request.auth.uid in resource.data.participants;
      allow create:       if isLoggedIn();

      match /messages/{messageId} {
        allow read, create: if isLoggedIn()
                            && request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants;
        allow update, delete: if false; // Messages immutable once sent
      }
    }

    // ========================================================================
    // 12. LOGISTICS ASSIGNMENTS
    // Covers: LogisticsRepositoryImpl
    // ========================================================================
    match /logistics_assignments/{assignmentId} {
      // streamActiveAssignment queries by orderId; buyer or agent reads
      allow get: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.deliveryAgentId == request.auth.uid
      );
      allow list: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.deliveryAgentId == request.auth.uid ||
        hasRole('admin') || hasRole('superAdmin')
      );

      // Agent updates coordinates and advances status
      allow update: if isLoggedIn()
                    && resource.data.deliveryAgentId == request.auth.uid
                    && request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['currentLatitude', 'currentLongitude', 'status', 'updatedTime']);

      allow create, delete: if false; // Backend only
    }

    // ========================================================================
    // 13. DISPUTES
    // Covers: AdminRepositoryImpl.fetchActiveDisputes, updateTicketStatus
    // ========================================================================
    match /disputes/{ticketId} {
      allow create: if isLoggedIn();
      allow get:    if isLoggedIn() && (resource.data.reporterId == request.auth.uid || hasRole('admin') || hasRole('superAdmin'));
      allow list:   if hasRole('admin') || hasRole('superAdmin');
      allow update: if hasRole('admin') || hasRole('superAdmin');
      allow delete: if hasRole('superAdmin');
    }

    // ========================================================================
    // 14. PLATFORM SETTINGS
    // Covers: AdminRepositoryImpl.fetchSystemGlobalConfigurations,
    //         patchCommissionStructure
    // ========================================================================
    match /platform_settings/{docId} {
      allow read:  if true; // Public config (rate limits etc.)
      allow write: if hasRole('admin') || hasRole('superAdmin');
    }

    // ========================================================================
    // 15. REVIEWS  (indexes reference this collection — rules needed)
    // ========================================================================
    match /reviews/{reviewId} {
      allow read:   if true;
      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 2000
                    && request.resource.data.productId is string;
      allow update: if false;
      allow delete: if isLoggedIn() && (
        resource.data.userId == request.auth.uid ||
        hasRole('admin') || hasRole('superAdmin')
      );
    }

    // ========================================================================
    // 16. CATEGORIES
    // ========================================================================
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if hasRole('admin') || hasRole('superAdmin');
    }

    // ========================================================================
    // 17. CATEGORY REQUESTS
    // ========================================================================
    match /category_requests/{requestId} {
      allow read: if isLoggedIn() && (resource.data.sellerId == request.auth.uid || hasRole('admin') || hasRole('superAdmin'));
      allow list: if isLoggedIn() && (resource.data.sellerId == request.auth.uid || hasRole('admin') || hasRole('superAdmin'));
      allow create: if isLoggedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if hasRole('admin') || hasRole('superAdmin');
      allow delete: if hasRole('superAdmin');
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if hasRole('admin') || hasRole('superAdmin');
    }
  }
}
