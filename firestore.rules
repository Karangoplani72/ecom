rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isLoggedIn() && role in getUserData().roles;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superAdmin');
    }

    function isString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isNumber(value, min, max) {
      return (value is int || value is float) && value >= min && value <= max;
    }



    function isStoreOwner(storeId) {
      return isLoggedIn() && request.auth.uid == storeId;
    }

    function isStoreMember(storeId) {
      return isLoggedIn() && (request.auth.uid == storeId || getUserData().get('storeId', '') == storeId);
    }

    function hasStaffPermission(storeId, permission) {
      return isLoggedIn() &&
             getUserData().get('storeId', '') == storeId &&
             hasRole('storeManager') &&
             get(/databases/$(database)/documents/stores/$(storeId)/staff/$(request.auth.uid)).data.get('permissions', []).hasAny([permission]);
    }

    function isStoreOwnerOrHasPerm(storeId, permission) {
      return isStoreOwner(storeId) || isAdmin() || hasStaffPermission(storeId, permission);
    }

    // =========================================================================
    // USERS
    // =========================================================================
    match /users/{userId} {
      allow get:    if isOwner(userId) || isAdmin() || hasRole('seller') || hasRole('storeManager');
      allow list:   if isAdmin() || hasRole('seller') || hasRole('storeManager');

      allow create: if isLoggedIn()
                    && isOwner(userId)
                    && request.resource.data.roles == ['buyer']
                    && (!('walletBalance' in request.resource.data) || request.resource.data.walletBalance == 0)
                    && (!('isActive' in request.resource.data) || request.resource.data.isActive == true)
                    && (!('sellerApproved' in request.resource.data) || request.resource.data.sellerApproved == false)
                    && (!('sellerApplicationStatus' in request.resource.data) || request.resource.data.sellerApplicationStatus == 'none');

      allow update: if isAdmin()
                    || (isOwner(userId)
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'isActive', 'walletBalance', 'sellerApproved'])
                        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['sellerApplicationStatus'])
                            || request.resource.data.sellerApplicationStatus == 'pending'))
                    || ( (hasRole('seller') || hasRole('storeManager'))
                         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['storeId', 'roles'])
                         && request.resource.data.storeId == getUserData().get('storeId', request.auth.uid)
                         && request.resource.data.roles.hasAll(resource.data.roles)
                         && request.resource.data.roles.size() <= resource.data.roles.size() + 1
                       )
                    || ( isOwner(userId)
                         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['storeId', 'roles'])
                         && request.resource.data.roles.hasAll(resource.data.roles)
                         && request.resource.data.roles.hasAny(['storeManager'])
                         && exists(/databases/$(database)/documents/store_invitations/$(request.auth.token.email))
                         && request.resource.data.storeId == get(/databases/$(database)/documents/store_invitations/$(request.auth.token.email)).data.storeId
                       );

      allow delete: if hasRole('superAdmin');

      match /tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /recent_searches/{searchId} {
        allow read, write: if isOwner(userId);
      }

      // Notifications: allow cross-user create for order flow (seller->buyer, admin->seller)
      match /notifications/{notifId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow create: if isLoggedIn()
                      && request.resource.data.title is string
                      && request.resource.data.body is string
                      && (!('isRead' in request.resource.data) || request.resource.data.isRead == false);
        allow update: if (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
                      || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // =========================================================================
    // STORES
    // =========================================================================
    match /stores/{storeId} {
      allow get:  if resource.data.status == 'verified'
                  || isStoreMember(storeId)
                  || isAdmin();
      allow list: if isAdmin();

      allow create: if isAdmin();
      allow update: if isStoreOwnerOrHasPerm(storeId, 'settings') 
                    || isStoreOwnerOrHasPerm(storeId, 'storeProfile')
                    || isAdmin();
      allow delete: if hasRole('superAdmin');

      match /products/{productId} {
        allow get:  if isStoreOwnerOrHasPerm(storeId, 'inventory');
        allow list: if isStoreOwnerOrHasPerm(storeId, 'inventory');
        allow create, delete: if isStoreOwnerOrHasPerm(storeId, 'inventory');
        allow update: if isStoreOwnerOrHasPerm(storeId, 'inventory')
                      || (isLoggedIn()
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metadata', 'status', 'updatedAt'])
                          && request.resource.data.metadata.stock <= resource.data.metadata.stock);
      }
      match /staff/{staffId} {
        allow get:    if isStoreOwnerOrHasPerm(storeId, 'staff') || request.auth.uid == staffId;
        allow list:   if isStoreOwnerOrHasPerm(storeId, 'staff');
        allow create: if isStoreOwnerOrHasPerm(storeId, 'staff') || (request.auth.uid == staffId && exists(/databases/$(database)/documents/store_invitations/$(request.auth.token.email)));
        allow update: if isStoreOwnerOrHasPerm(storeId, 'staff');
        allow delete: if isStoreOwnerOrHasPerm(storeId, 'staff') || request.auth.uid == staffId;
      }
    }

    // =========================================================================
    // CATALOG
    // =========================================================================
    match /catalog/{productId} {
      allow get: if resource.data.status == 'active'
                 || isLoggedIn();
      allow list: if true;

      allow create: if isLoggedIn()
                    && isStoreOwnerOrHasPerm(request.resource.data.storeId, 'inventory')
                    && isString(request.resource.data.title, 1, 200)
                    && isNumber(request.resource.data.basePrice, 0.01, 10000000);

      allow update: if isAdmin()
                    || (isLoggedIn() && isStoreOwnerOrHasPerm(resource.data.storeId, 'inventory'))
                    || (isLoggedIn()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metadata', 'status', 'updatedAt'])
                        && request.resource.data.metadata.stock <= resource.data.metadata.stock);

      allow delete: if isLoggedIn() && isStoreOwnerOrHasPerm(resource.data.storeId, 'inventory');
    }

    // =========================================================================
    // ORDERS
    // =========================================================================
    match /orders/{orderId} {
      allow get:  if isLoggedIn() && (resource.data.buyerId == request.auth.uid || isStoreOwnerOrHasPerm(resource.data.storeId, 'orders'));
      allow list: if isLoggedIn()
                  && (resource.data.buyerId == request.auth.uid
                      || isStoreOwnerOrHasPerm(resource.data.storeId, 'orders')
                      || isAdmin());

      allow create: if isLoggedIn()
                    && request.resource.data.buyerId == request.auth.uid
                    && (!('status' in request.resource.data) || request.resource.data.status == 'pending');

      allow update: if (isAdmin()
                    && (request.resource.data.get('status', '') != 'refunded'
                        || (request.resource.data.get('refundReason', '').size() >= 10
                            && request.resource.data.get('refundedBy', '') is string)))
                    || (isLoggedIn()
                        && isStoreOwnerOrHasPerm(resource.data.storeId, 'orders')
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'status', 'updatedAt', 'shippingStatus', 'trackingNumber',
                             'estimatedDeliveryDate', 'paymentStatus', 'carrier', 'deliveryNotes'
                           ]))
                    || (isLoggedIn()
                        && resource.data.buyerId == request.auth.uid
                        && request.resource.data.status in ['cancelled', 'returnRequested']
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));

      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // CHATS
    // =========================================================================
    match /chats/{chatId} {
      allow get: if isLoggedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == 'admin_support' || isStoreOwnerOrHasPerm(resource.data.sellerId, 'messages') || isAdmin());
      allow list: if isLoggedIn();
      allow create: if isLoggedIn() && (request.resource.data.buyerId == request.auth.uid || isStoreOwnerOrHasPerm(request.resource.data.sellerId, 'messages') || isAdmin());
      allow update: if isLoggedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == 'admin_support' || isStoreOwnerOrHasPerm(resource.data.sellerId, 'messages') || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow update: if isLoggedIn() && resource.data.senderId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // =========================================================================
    // SELLER APPLICATIONS
    // =========================================================================
    match /sellerApplications/{applicationId} {
      allow get:  if isLoggedIn() && (applicationId == request.auth.uid || isAdmin());
      allow list: if isAdmin();

      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid
                    && applicationId == request.auth.uid
                    && request.resource.data.status == 'pending';

      allow update: if isAdmin()
                    || (isLoggedIn()
                        && applicationId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'reviewedAt', 'reviewedBy', 'rejectionReason']));

      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // FINANCIAL
    // =========================================================================
    match /payment_failures/{failureId} {
      allow create: if isLoggedIn()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.razorpayOrderId is string
                    && request.resource.data.errorMessage is string;
      allow read:   if isLoggedIn() && (resource.data.buyerId == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    match /transactions/{transactionId} {
      allow get:  if isLoggedIn() && (resource.data.buyerId == request.auth.uid
                                       || isStoreOwnerOrHasPerm(resource.data.storeId, 'finances'));
      allow list: if isLoggedIn()
                  && (resource.data.buyerId == request.auth.uid
                      || isStoreOwnerOrHasPerm(resource.data.storeId, 'finances')
                      || isAdmin());
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // =========================================================================
    // WALLETS
    // =========================================================================
    match /wallets/{sellerId} {
      allow read:   if isLoggedIn() && (isStoreOwnerOrHasPerm(sellerId, 'finances'));
      allow update: if isAdmin() && request.resource.data.balance >= 0;
      allow create, delete: if false;
    }

    // =========================================================================
    // PAYOUTS
    // =========================================================================
    match /payouts/{payoutId} {
      allow read:   if isLoggedIn() && (isStoreOwnerOrHasPerm(resource.data.storeId, 'finances'));
      allow list:   if isLoggedIn()
                    && (isStoreOwnerOrHasPerm(resource.data.storeId, 'finances') || isAdmin());
      allow create: if isLoggedIn()
                    && isStoreOwnerOrHasPerm(request.resource.data.storeId, 'finances')
                    && request.resource.data.status == 'pending'
                    && isNumber(request.resource.data.amount, 0.01, 100000000);
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'status', 'processedAt', 'completedAt', 'rejectedAt', 'rejectionReason', 'updatedAt', 'adminNote'
                       ]);
      allow delete: if false;
    }

    match /escrows/{escrowId} {
      allow read: if isLoggedIn() && (
        resource == null || 
        isStoreOwnerOrHasPerm(resource.data.storeId, 'finances') || 
        isAdmin()
      );
      allow update: if isLoggedIn()
                    && isStoreOwnerOrHasPerm(resource.data.storeId, 'finances')
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'releaseRequestedAt', 'releaseTarget', 'releaseReason'])
                    && request.resource.data.status == 'release_requested';
      allow create, delete: if false;
    }

    // =========================================================================
    // STORE INVITATIONS
    // =========================================================================
    match /store_invitations/{invitationId} {
      allow get:    if isLoggedIn() && (resource == null || isStoreOwnerOrHasPerm(resource.data.storeId, 'staff') || request.auth.token.email == resource.data.email);
      allow list:   if isLoggedIn() && (resource == null || isStoreOwnerOrHasPerm(resource.data.storeId, 'staff') || request.auth.token.email == resource.data.email);
      allow create: if isLoggedIn() && isStoreOwnerOrHasPerm(request.resource.data.storeId, 'staff');
      allow update: if isLoggedIn() && isStoreOwnerOrHasPerm(request.resource.data.storeId, 'staff');
      allow delete: if isLoggedIn() && (isStoreOwnerOrHasPerm(resource.data.storeId, 'staff') || request.auth.token.email == resource.data.email || request.auth.token.email == invitationId);
    }

    // =========================================================================
    // BANK ACCOUNTS  (accountId == sellerId)
    // =========================================================================
    match /bankAccounts/{accountId} {
      allow read:          if isLoggedIn() && (isStoreOwnerOrHasPerm(accountId, 'finances'));
      allow create, update: if isAdmin()
                            || (isLoggedIn()
                                && isStoreOwnerOrHasPerm(request.resource.data.storeId, 'finances')
                                && isString(request.resource.data.bankName, 1, 100)
                                && isString(request.resource.data.accountNumber, 5, 30)
                                && isString(request.resource.data.ifscCode, 5, 20)
                                && isString(request.resource.data.accountHolderName, 2, 100)
                                && (!('isVerified' in request.resource.data) || request.resource.data.isVerified == false));
      allow delete: if false;
    }

    // =========================================================================
    // SELLERS  (sellerId == request.auth.uid)
    // =========================================================================
    match /sellers/{sellerId} {
      allow get, list: if isOwner(sellerId) || isStoreMember(sellerId) || isAdmin();
      allow write:     if false;

      match /bankDetails/{docId} {
        allow get, list: if isStoreOwnerOrHasPerm(sellerId, 'finances');
        allow create, update: if isAdmin()
                              || (isStoreOwnerOrHasPerm(sellerId, 'finances')
                                  && isString(request.resource.data.ifsc, 4, 20)
                                  && isString(request.resource.data.accountNumber, 5, 30)
                                  && isString(request.resource.data.holderName, 2, 100)
                                  && isString(request.resource.data.bankName, 1, 100)
                                  && isString(request.resource.data.maskedAccountNumber, 4, 30));
        allow delete: if false;
      }
    }

    // =========================================================================
    // CHATS & MESSAGES
    // Rooms are keyed by sorted(buyerId + '_' + sellerId).
    // Only the two participants may access the room and its messages.
    // Admins may list rooms for moderation purposes.
    // =========================================================================
    match /chats/{roomId} {
      function isParticipant() {
        let uData = getUserData();
        let sId = uData.get('storeId', '');
        return isLoggedIn() && (
          resource == null ||
          request.auth.uid in resource.data.participants || 
          (sId != '' && sId == resource.data.sellerId && hasStaffPermission(sId, 'messages'))
        );
      }

      function isCreatorParticipant() {
        let uData = getUserData();
        let sId = uData.get('storeId', '');
        return isLoggedIn() && (
          request.auth.uid in request.resource.data.participants || 
          (sId != '' && sId == request.resource.data.sellerId && hasStaffPermission(sId, 'messages'))
        );
      }

      allow get:    if isParticipant() || isAdmin();
      allow list:   if isAdmin() || isParticipant();

      // A participant can create a new room. The participants array must
      // contain exactly two elements and must include the creator.
      allow create: if isLoggedIn()
                    && request.resource.data.participants.size() == 2
                    && isCreatorParticipant()
                    && request.resource.data.buyerId is string
                    && request.resource.data.sellerId is string;

      // Participants may update metadata (lastMessage, unreadCounts,
      // typing indicators). They cannot change participants list or
      // buyerId/sellerId identity fields.
      allow update: if (isParticipant()
                        && !request.resource.data.diff(resource.data)
                            .affectedKeys().hasAny(['participants', 'buyerId', 'sellerId']))
                    || isAdmin();

      allow delete: if false;

      match /messages/{messageId} {
        function roomParticipants() {
          return get(/databases/$(database)/documents/chats/$(roomId)).data.participants;
        }
        function roomSellerId() {
          return get(/databases/$(database)/documents/chats/$(roomId)).data.sellerId;
        }

        allow read:   if isLoggedIn() && (
          request.auth.uid in roomParticipants() || 
          (getUserData().get('storeId', '') != '' && getUserData().get('storeId', '') == roomSellerId() && hasStaffPermission(getUserData().get('storeId', ''), 'messages'))
        );

        allow create: if isLoggedIn()
                      && (
                        request.auth.uid in roomParticipants() || 
                        (getUserData().get('storeId', '') != '' && getUserData().get('storeId', '') == roomSellerId() && hasStaffPermission(getUserData().get('storeId', ''), 'messages'))
                      )
                      && (request.resource.data.senderId == request.auth.uid || request.resource.data.senderId == roomSellerId())
                      && (
                           (request.resource.data.type == 'text'
                            && isString(request.resource.data.text, 1, 4000))
                           || request.resource.data.type == 'image'
                         );

        // Messages are immutable — no edits, no deletes (by clients).
        allow update, delete: if false;
      }
    }

    // =========================================================================
    // LOGISTICS ASSIGNMENTS
    // =========================================================================
    match /logistics_assignments/{assignmentId} {
      allow get:  if isLoggedIn() && (resource.data.buyerId == request.auth.uid
                                       || resource.data.deliveryAgentId == request.auth.uid
                                       || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isLoggedIn()
                        && resource.data.deliveryAgentId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'currentLatitude', 'currentLongitude', 'status', 'updatedTime'
                           ]));
      allow delete: if false;
    }

    // =========================================================================
    // DISPUTES
    // =========================================================================
    match /disputes/{ticketId} {
      allow create: if isLoggedIn()
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && isString(request.resource.data.reason, 1, 1000);
      allow get:    if isLoggedIn() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow list:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // PLATFORM SETTINGS
    // =========================================================================
    match /platform_settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // =========================================================================
    // REVIEWS
    // =========================================================================
    match /reviews/{reviewId} {
      allow read:   if true;
      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid
                    && isNumber(request.resource.data.rating, 1, 5)
                    && isString(request.resource.data.text, 0, 2000)
                    && isString(request.resource.data.productId, 1, 100);
      allow update: if isAdmin();
      allow delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // =========================================================================
    // CATEGORIES & COUPONS
    // =========================================================================
    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || (isLoggedIn()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount', 'usedBy'])
                        && request.resource.data.usageCount == resource.data.usageCount + 1
                        && request.resource.data.usedBy.size() == resource.data.usedBy.size() + 1
                        && request.resource.data.usedBy.hasAny([request.auth.uid])
                        && resource.data.usedBy.hasOnly(request.resource.data.usedBy));
    }

    // =========================================================================
    // CATEGORY REQUESTS
    // =========================================================================
    match /category_requests/{requestId} {
      allow get:    if isLoggedIn() && (isStoreOwnerOrHasPerm(resource.data.sellerId, 'inventory') || isAdmin());
      allow list:   if isAdmin();
      allow create: if isLoggedIn()
                    && isStoreOwnerOrHasPerm(request.resource.data.sellerId, 'inventory')
                    && request.resource.data.status == 'pending'
                    && isString(request.resource.data.name, 1, 100);
      allow update: if isAdmin();
      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // USER PROFILES  (public photo/display cache)
    // =========================================================================
    match /user_profiles/{userId} {
      allow read:  if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // =========================================================================
    // SETTLEMENTS
    // =========================================================================
    match /settlements/{settlementId} {
      allow get:    if isAdmin() || isStoreOwnerOrHasPerm(resource.data.sellerId, 'finances');
      allow list:   if isAdmin();
      allow create: if false;
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'status', 'processedAt', 'completedAt', 'rejectedAt', 'rejectionReason', 'updatedAt', 'adminNote'
                       ]);
      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // AUDIT LOGS
    // =========================================================================
    match /audit_logs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isLoggedIn();
      allow update, delete: if false;
    }
  }
}
