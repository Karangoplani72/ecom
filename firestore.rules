rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // 1. CORE AUTHENTICATION FUNCTIONS
    // ========================================================================
    function isLoggedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isLoggedIn() && role in getUserData().roles;
    }
    
    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    // ========================================================================
    // 2. USER IDENTITY & IAM (Section 1)
    // ========================================================================
    match /users/{userId} {
      // Users can read/write their own profiles. Admins can read all.
      allow read: if isOwner(userId) || hasRole('admin') || hasRole('superAdmin');
      
      // Prevent users from elevating their own privileges during creation/updates
      allow create, update: if isOwner(userId) 
                            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'isActive', 'walletBalance']));
      allow delete: if hasRole('superAdmin');
      
      // Subcollection: Push Notification Tokens
      match /tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ========================================================================
    // 3. CATALOG & MERCHANTS (Sections 2 & 4)
    // ========================================================================
    match /stores/{storeId} {
      // Anyone can view active stores
      allow read: if resource.data.status == 'verified' || hasRole('admin');
      
      // Only the specific seller who owns the store (or an admin) can edit it
      allow update: if (isLoggedIn() && resource.data.sellerId == request.auth.uid) || hasRole('admin');
      allow create, delete: if hasRole('admin'); // Store creation requires admin approval

      match /products/{productId} {
        // Public can read active items. Sellers can read all their own items.
        allow read: if resource.data.status == 'active' || (isLoggedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.sellerId == request.auth.uid);
        
        // Only the store owner can manage their inventory
        allow write: if isLoggedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.sellerId == request.auth.uid;
      }
    }

    // ========================================================================
    // 4. FINANCIAL LEDGER & PAYMENTS (Section 5)
    // ========================================================================
    match /payment_intents/{intentId} {
      allow create: if isLoggedIn(); // Buyers can initiate checkouts
      // Users can only read their own intents to prevent snooping on other's orders
      allow read: if isLoggedIn() && resource.data.buyerId == request.auth.uid;
      allow update, delete: if false; // Only Cloud Functions can mutate ledger states!
    }

    match /transactions/{transactionId} {
      // Buyers can see their receipts, sellers can see their incoming payouts
      allow read: if isLoggedIn() && (resource.data.buyerId == request.auth.uid || resource.data.storeId == getUserData().activeStoreId);
      allow write: if false; // STRICT: Only Cloud Functions can write receipts
    }

    // ========================================================================
    // 5. CHAT & REAL-TIME COMMS (Section 6)
    // ========================================================================
    match /chats/{roomId} {
      // Allow access only if the user's ID is in the participants array
      allow read, update: if isLoggedIn() && request.auth.uid in resource.data.participants;
      allow create: if isLoggedIn();
      
      match /messages/{messageId} {
        // Must be a participant of the parent room to read/write messages
        allow read, create: if isLoggedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants;
        allow update, delete: if false; // Messages cannot be altered once sent
      }
    }

    // ========================================================================
    // 6. LOGISTICS & DELIVERY (Section 7)
    // ========================================================================
    match /logistics_assignments/{assignmentId} {
      // Buyers can read their own deliveries; assigned agents can read theirs
      allow read: if isLoggedIn() && (resource.data.buyerId == request.auth.uid || resource.data.deliveryAgentId == request.auth.uid);
      
      // Only the assigned agent can update the live coordinates
      allow update: if isLoggedIn() && resource.data.deliveryAgentId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentLatitude', 'currentLongitude', 'status', 'updatedTime']);
      allow create, delete: if false; // Generated via backend
    }

    // ========================================================================
    // 7. PLATFORM GOVERNANCE (Section 8)
    // ========================================================================
    match /disputes/{ticketId} {
      allow create: if isLoggedIn(); // Anyone can file a ticket
      allow read: if isLoggedIn() && (resource.data.reporterId == request.auth.uid || hasRole('admin'));
      allow update: if hasRole('admin'); // Only admins can resolve tickets
      allow delete: if hasRole('superAdmin');
    }

    match /platform_settings/{docId} {
      allow read: if true; // Public configuration variables (like rate limits)
      allow write: if hasRole('superAdmin');
    }

    // ========================================================================
    // 8. ORDERS & CHECKOUT
    // ========================================================================
    match /orders/{orderId} {
      allow read: if isLoggedIn() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.storeId == request.auth.uid ||
        hasRole('admin')
      );
      allow create: if isLoggedIn() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isLoggedIn() && (
        (resource.data.storeId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        hasRole('admin')
      );
      allow delete: if hasRole('superAdmin');
    }
  }
}
