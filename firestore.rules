rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isLoggedIn() && role in getUserData().roles;
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superAdmin');
    }

    function isString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isNumber(value, min, max) {
      return (value is int || value is float) && value >= min && value <= max;
    }

    function isList(value, max) {
      return value is list && value.size() <= max;
    }

    function isStoreOwner(storeId) {
      return isLoggedIn() && request.auth.uid == storeId;
    }

    // =========================================================================
    // USERS
    // =========================================================================
    match /users/{userId} {
      allow get:    if isOwner(userId) || isAdmin();
      allow list:   if isAdmin();
      // Allow admin to query by roles for dashboard metrics
      allow list:   if isAdmin();

      allow create: if isLoggedIn()
                    && isOwner(userId)
                    && request.resource.data.roles == ['buyer']
                    && (!('walletBalance' in request.resource.data) || request.resource.data.walletBalance == 0)
                    && (!('isActive' in request.resource.data) || request.resource.data.isActive == true)
                    && (!('sellerApproved' in request.resource.data) || request.resource.data.sellerApproved == false)
                    && (!('sellerApplicationStatus' in request.resource.data) || request.resource.data.sellerApplicationStatus == 'none');

      allow update: if isAdmin()
                    || (isOwner(userId)
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'isActive', 'walletBalance', 'sellerApproved'])
                        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['sellerApplicationStatus'])
                            || request.resource.data.sellerApplicationStatus == 'pending'));

      allow delete: if hasRole('superAdmin');

      match /tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      match /cart/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId);
      }

      match /recent_searches/{searchId} {
        allow read, write: if isOwner(userId);
      }

      // Notifications: allow cross-user create for order flow (seller->buyer, admin->seller)
      match /notifications/{notifId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow create: if isLoggedIn()
                      && request.resource.data.title is string
                      && request.resource.data.body is string
                      && (!('isRead' in request.resource.data) || request.resource.data.isRead == false);
        allow update: if (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
                      || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // =========================================================================
    // STORES
    // =========================================================================
    match /stores/{storeId} {
      allow get:  if resource.data.status == 'verified'
                  || isStoreOwner(storeId)
                  || isAdmin();
      allow list: if isAdmin() || isLoggedIn();

      allow create: if isAdmin();
      allow update: if isStoreOwner(storeId) || isAdmin();
      allow delete: if hasRole('superAdmin');

      // store doc id == sellerId; seller owns subcollection products
      match /products/{productId} {
        allow get:  if isStoreOwner(storeId) || isAdmin();
        allow list: if isStoreOwner(storeId) || isAdmin();
        // Seller write (CRUD) + authenticated buyer update for stock decrement during checkout
        allow create, delete: if isStoreOwner(storeId) || isAdmin();
        allow update: if isStoreOwner(storeId)
                      || isAdmin()
                      || (isLoggedIn()
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metadata', 'status', 'updatedAt'])
                          && request.resource.data.metadata.stock <= resource.data.metadata.stock);
      }
    }

    // =========================================================================
    // CATALOG
    // =========================================================================
    match /catalog/{productId} {
      // Public get for active products from verified stores
      allow get: if resource.data.status == 'active'
                 || isLoggedIn();

      allow list: if true;
      // Allow admin to query by status/stock for dashboard metrics
      allow list: if isAdmin();

      // Seller creates catalog items; storeId == sellerId (doc id)
      allow create: if isLoggedIn()
                    && request.resource.data.storeId == request.auth.uid
                    && isString(request.resource.data.title, 1, 200)
                    && isNumber(request.resource.data.basePrice, 0.01, 10000000);

      // Seller or admin update; also allow buyer to decrement stock (checkout)
      allow update: if isAdmin()
                    || (isLoggedIn() && resource.data.storeId == request.auth.uid)
                    || (isLoggedIn()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metadata', 'status', 'updatedAt'])
                        && request.resource.data.metadata.stock <= resource.data.metadata.stock);

      allow delete: if isLoggedIn() && resource.data.storeId == request.auth.uid;
    }

    // =========================================================================
    // ORDERS
    // =========================================================================
    match /orders/{orderId} {
      allow get:  if isLoggedIn() && (resource.data.buyerId == request.auth.uid || resource.data.storeId == request.auth.uid || isAdmin());
      allow list: if isLoggedIn() && (resource.data.buyerId == request.auth.uid || resource.data.storeId == request.auth.uid || isAdmin());
      // Allow admin to query by status for dashboard metrics
      allow list: if isAdmin();

      // Order creation: buyer client (COD/fallback) or Cloud Function (Admin SDK bypasses rules)
      allow create: if isLoggedIn()
                    && request.resource.data.buyerId == request.auth.uid
                    && (!('status' in request.resource.data) || request.resource.data.status == 'pending');

      // Seller updates status/tracking; buyer can cancel or request return
      allow update: if isAdmin()
                    || (isLoggedIn()
                        && resource.data.storeId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'status', 'updatedAt', 'shippingStatus', 'trackingNumber',
                             'estimatedDeliveryDate', 'paymentStatus', 'carrier', 'deliveryNotes'
                           ]))
                    || (isLoggedIn()
                        && resource.data.buyerId == request.auth.uid
                        && request.resource.data.status in ['cancelled', 'returnRequested']
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));

      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // SELLER APPLICATIONS
    // =========================================================================
    match /sellerApplications/{applicationId} {
      allow get:  if isLoggedIn() && (applicationId == request.auth.uid || isAdmin());
      allow list: if isAdmin();

      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid
                    && applicationId == request.auth.uid
                    && request.resource.data.status == 'pending';

      allow update: if isAdmin()
                    || (isLoggedIn()
                        && applicationId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'reviewedAt', 'reviewedBy', 'rejectionReason']));

      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // FINANCIAL
    // =========================================================================
    match /payment_failures/{failureId} {
      allow create: if isLoggedIn()
                    && request.resource.data.buyerId == request.auth.uid
                    && request.resource.data.razorpayOrderId is string
                    && request.resource.data.errorMessage is string;
      allow read:   if isLoggedIn() && (resource.data.buyerId == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    match /transactions/{transactionId} {
      allow get:  if isLoggedIn() && (resource.data.buyerId == request.auth.uid
                                       || resource.data.storeId == request.auth.uid
                                       || isAdmin());
      allow list: if isLoggedIn() && (resource.data.buyerId == request.auth.uid
                                       || resource.data.storeId == request.auth.uid
                                       || isAdmin());
      allow write: if false;
    }

    // =========================================================================
    // WALLETS
    // =========================================================================
    match /wallets/{sellerId} {
      allow read:  if isLoggedIn() && request.auth.uid == sellerId;
      allow write: if false;
    }

    // =========================================================================
    // PAYOUTS
    // =========================================================================
    match /payouts/{payoutId} {
      allow read:   if isLoggedIn() && (resource.data.storeId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn()
                    && request.resource.data.storeId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && isNumber(request.resource.data.amount, 0.01, 100000000);
      allow update, delete: if false;
    }

    match /escrows/{escrowId} {
      allow read, write: if false;
    }

    // =========================================================================
    // BANK ACCOUNTS  (accountId == sellerId)
    // =========================================================================
    match /bankAccounts/{accountId} {
      allow read:          if isLoggedIn() && (request.auth.uid == accountId || isAdmin());
      allow create, update: if isAdmin()
                            || (isLoggedIn()
                                && request.auth.uid == accountId
                                && request.resource.data.storeId == request.auth.uid
                                && isString(request.resource.data.bankName, 1, 100)
                                && isString(request.resource.data.accountNumber, 5, 30)
                                && isString(request.resource.data.ifscCode, 5, 20)
                                && isString(request.resource.data.accountHolderName, 2, 100)
                                && (!('isVerified' in request.resource.data) || request.resource.data.isVerified == false));
      allow delete: if false;
    }

    // =========================================================================
    // SELLERS  (sellerId == request.auth.uid; holds bank details used by the
    // seller Finances page — SellerFinanceRepositoryImpl.updateBankAccount /
    // sellerBankAccountProvider read+write /sellers/{sellerId}/bankDetails/primary)
    // =========================================================================
    match /sellers/{sellerId} {
      allow get, list: if isOwner(sellerId) || isAdmin();
      allow write:     if false; // no top-level seller doc is written by the app

      match /bankDetails/{docId} {
        allow get, list: if isOwner(sellerId) || isAdmin();
        allow create, update: if isAdmin()
                              || (isOwner(sellerId)
                                  && isString(request.resource.data.ifsc, 4, 20)
                                  && isString(request.resource.data.accountNumber, 5, 30)
                                  && isString(request.resource.data.holderName, 2, 100)
                                  && isString(request.resource.data.bankName, 1, 100)
                                  // accountNumber must never be written back unmasked once stored,
                                  // and the client must always supply a masked mirror of it
                                  && isString(request.resource.data.maskedAccountNumber, 4, 30));
        allow delete: if false;
      }
    }

    // =========================================================================
    // CHATS & MESSAGES
    // =========================================================================
    match /chats/{roomId} {
      allow read:   if isLoggedIn() && request.auth.uid in resource.data.participants;
      allow list:   if isAdmin();
      allow create: if isLoggedIn()
                    && isList(request.resource.data.participants, 10)
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isLoggedIn()
                    && request.auth.uid in resource.data.participants
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if isLoggedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants;
        // Allow first-message create before room doc exists (app writes message then room)
        allow create: if isLoggedIn()
                      && request.resource.data.senderId == request.auth.uid
                      && isString(request.resource.data.text, 1, 2000)
                      && (!exists(/databases/$(database)/documents/chats/$(roomId))
                          || request.auth.uid in get(/databases/$(database)/documents/chats/$(roomId)).data.participants);
        allow update, delete: if false;
      }
    }

    // =========================================================================
    // LOGISTICS ASSIGNMENTS
    // =========================================================================
    match /logistics_assignments/{assignmentId} {
      allow get:  if isLoggedIn() && (resource.data.buyerId == request.auth.uid
                                       || resource.data.deliveryAgentId == request.auth.uid
                                       || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isLoggedIn()
                        && resource.data.deliveryAgentId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'currentLatitude', 'currentLongitude', 'status', 'updatedTime'
                           ]));
      allow delete: if false;
    }

    // =========================================================================
    // DISPUTES
    // =========================================================================
    match /disputes/{ticketId} {
      allow create: if isLoggedIn()
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && isString(request.resource.data.reason, 1, 1000);
      allow get:    if isLoggedIn() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow list:   if isAdmin();
      // Allow admin to query by status for dashboard metrics
      allow list:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // PLATFORM SETTINGS
    // =========================================================================
    match /platform_settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // =========================================================================
    // REVIEWS
    // =========================================================================
    match /reviews/{reviewId} {
      allow read:   if true;
      allow create: if isLoggedIn()
                    && request.resource.data.userId == request.auth.uid
                    && isNumber(request.resource.data.rating, 1, 5)
                    && isString(request.resource.data.text, 0, 2000)
                    && isString(request.resource.data.productId, 1, 100);
      allow update: if isAdmin();
      allow delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // =========================================================================
    // CATEGORIES & COUPONS
    // =========================================================================
    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // =========================================================================
    // CATEGORY REQUESTS
    // =========================================================================
    match /category_requests/{requestId} {
      allow get:    if isLoggedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow list:   if isAdmin()
                    || (isLoggedIn() && resource.data.sellerId == request.auth.uid);
      // Allow admin to list all category requests without sellerId restriction
      allow list:   if isAdmin();
      allow create: if isLoggedIn()
                    && request.resource.data.sellerId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && isString(request.resource.data.name, 1, 100);
      allow update: if isAdmin();
      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // USER PROFILES  (public photo/display cache)
    // =========================================================================
    match /user_profiles/{userId} {
      allow read:  if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // =========================================================================
    // SETTLEMENTS
    // =========================================================================
    match /settlements/{settlementId} {
      allow get:    if isAdmin() || resource.data.sellerId == request.auth.uid;
      allow list:   if isAdmin();
      allow create: if false; // Created by Cloud Functions only
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'status', 'processedAt', 'rejectedAt', 'updatedAt'
                       ]);
      allow delete: if hasRole('superAdmin');
    }

    // =========================================================================
    // AUDIT LOGS
    // =========================================================================
    match /audit_logs/{logId} {
      allow read:          if isAdmin();
      allow create:        if isLoggedIn();
      allow update, delete: if false;
    }
  }
}